{
  "name": "@citolab/qti-convert-tao-pci",
  "version": "0.4.10",
  "description": "TAO PCI conversion helpers for qti-convert",
  "type": "module",
  "license": "Apache-2.0",
  "repository": "https://github.com/Citolab/qti-convert",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/runtime.ts --format esm --target node18 --dts --outDir dist",
    "build:yalc": "npm run build && yalc publish --push",
    "test": "vitest --project=unit --run",
    "test:storybook": "npm run prepare:storybook-assets && vitest --project=storybook --run",
    "prepare:storybook-assets": "node scripts/prepare-storybook-assets.mjs",
    "storybook": "npm run prepare:storybook-assets && storybook dev -p 6010",
    "build-storybook": "npm run prepare:storybook-assets && storybook build"
  },
  "dependencies": {
    "@citolab/qti-browser-import": "^0.4.10",
    "@citolab/qti-convert": "^0.4.10",
    "cheerio": "^1.2.0"
  },
  "overrides": {
    "brace-expansion": "2.0.3",
    "picomatch": "4.0.4",
    "undici": "7.24.0",
    "vite": "7.3.2",
    "archiver-utils": {
      "lodash": "4.18.1"
    }
  },
  "devDependencies": {
    "@citolab/qti-components": "^7.26.0",
    "@storybook/addon-a11y": "^10.2.7",
    "@storybook/addon-docs": "^10.2.7",
    "@storybook/addon-vitest": "^10.2.7",
    "@storybook/web-components-vite": "^10.2.7",
    "@vitest/browser-playwright": "^4.0.18",
    "jszip": "^3.10.1",
    "lodash": "^4.18.1",
    "playwright": "^1.58.2",
    "storybook": "^10.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
