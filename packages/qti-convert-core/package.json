{
  "name": "@citolab/qti-convert",
  "version": "0.4.15",
  "description": "QTI converter - Core functionality",
  "type": "module",
  "license": "Apache-2.0",
  "repository": "https://github.com/Citolab/qti-convert",
  "author": "Marcel Hoekstra",
  "contributors": [
    "Sander Looise",
    "Patrick de Klein",
    "Marcel Hoekstra"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "exports": {
    "./qti-convert": {
      "types": "./dist/qti-converter/index.d.ts",
      "default": "./dist/qti-converter/index.js"
    },
    "./qti-convert-node": {
      "types": "./dist/qti-converter-node/index.d.ts",
      "default": "./dist/qti-converter-node/index.js"
    },
    "./qti-loader": {
      "types": "./dist/qti-loader/index.d.ts",
      "default": "./dist/qti-loader/index.js"
    },
    "./qti-transformer": {
      "types": "./dist/qti-transformer/index.d.ts",
      "default": "./dist/qti-transformer/index.js"
    },
    "./qti-helper": {
      "types": "./dist/qti-helper/index.d.ts",
      "default": "./dist/qti-helper/index.js"
    },
    "./qti-helper-node": {
      "types": "./dist/qti-helper-node/index.d.ts",
      "default": "./dist/qti-helper-node/index.js"
    }
  },
  "files": [
    "dist",
    "src/assets"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cheerio": "^1.2.0",
    "jszip": "^3.10.1",
    "saxon-js": "^2.7.0",
    "unzipper": "^0.12.3",
    "xml-formatter": "^3.6.7"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.4.0",
    "@types/unzipper": "^0.10.11",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
