{
  "name": "qti-convert-workspace",
  "repository": "https://github.com/Citolab/qti-convert",
  "description": "QTI converter - Workspace",
  "author": "Marcel Hoekstra",
  "contributors": [
    "Sander Looise",
    "Patrick de Klein",
    "Marcel Hoekstra"
  ],
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=16.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:browser-import && npm run build:local-ai && npm run build:tao-pci && npm run build:cli",
    "build:core": "npm run build --workspace=@citolab/qti-convert",
    "build:browser-import": "npm run build --workspace=@citolab/qti-browser-import",
    "build:local-ai": "npm run build --workspace=@citolab/qti-convert-local-ai",
    "build:cli": "npm run build --workspace=@citolab/qti-convert-cli",
    "build:tao-pci": "npm run build --workspace=@citolab/qti-convert-tao-pci",
    "test": "npm run test --workspaces --if-present",
    "test:core": "npm run test --workspace=@citolab/qti-convert",
    "test:cli": "npm run test --workspace=@citolab/qti-convert-cli",
    "test:tao-pci": "npm run test --workspace=@citolab/qti-convert-tao-pci",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "rimraf packages/*/dist",
    "deploy": "firebase deploy --only hosting:qti-components",
    "list-outdated-dependencies": "npx npm-check-updates --format repo --peer",
    "update-dependencies": "npx npm-check-updates --peer -u && npm install",
    "publish:all": "node scripts/publish-all.mjs",
    "publish:all:dry-run": "node scripts/publish-all.mjs --dry-run --allow-dirty",
    "yalc:push:tao-pci": "cd packages/qti-convert-tao-pci && yalc publish --push"
  },
  "overrides": {
    "vite": "7.3.2",
    "archiver-utils": {
      "lodash": "4.18.1"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@jest/globals": "^30.4.1",
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "jest-environment-jsdom": "^30.4.1",
    "lodash": "^4.18.1",
    "nodemon": "^3.1.14",
    "path-browserify": "^1.0.1",
    "prettier": "3.8.3",
    "qti30upgrader": "github:Citolab/qti30Upgrader",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "xml2js": "^0.6.2"
  }
}
